# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
# Keep the lockfile tracked: the Docker build runs `npm ci`, which requires it.
# Overrides a `package-lock.json` entry in a contributor's global gitignore.
!package-lock.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# graphify knowledge-graph output (generated tooling artifacts, not app source)
/graphify-out/

# local onboarding doc (generated, not app source)
/ONBOARDING.md

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Beads / Dolt files (added by bd init)
# .beads holds local tracker state (embedded Dolt DB, config, logs) — not app source.
.beads/
.dolt/
*.db
.beads-credential-key

# Claude Code git worktrees — transient working copies of the repo, never source.
# (Other .claude/ files like commands/ and settings.json stay tracked.)
.claude/worktrees/
